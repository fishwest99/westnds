generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id
  name          String
  email         String         @unique
  emailVerified Boolean        @default(false)
  image         String?
  isManager     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  accounts      Account[]
  consentForms  ConsentForm[]
  billingForms  BillingForm[]
  timeOffRequests TimeOffRequest[]
  workEntries   WorkEntry[]
  roleRequests  RoleRequest[]
  calendarEvents  CalendarEvent[]
  caseStudyForms CaseStudyForm[]
  medicalLienForms MedicalLienForm[]
  cases         PatientCase[]
  coverageRequests OnCallCoverageRequest[]
  missedHoursRequests MissedHoursRequest[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ConsentForm {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId          String?
  case            PatientCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  status          String   @default("draft")

  // Header
  companyReading    Boolean @default(false)
  companyServices   Boolean @default(false)
  patientName       String  @default("")
  dateOfBirth       String  @default("")
  dateOfService     String  @default("")
  surgeonName       String  @default("")
  procedure         String  @default("")

  // Modalities
  modalityABR    Boolean @default(false)
  modalityTEMG   Boolean @default(false)
  modalityEEG    Boolean @default(false)
  modalityTO4NMJ Boolean @default(false)
  modalityEMG    Boolean @default(false)
  modalityVEP    Boolean @default(false)
  modalityNVC    Boolean @default(false)
  modalitySSEP   Boolean @default(false)
  modalityTcMEP  Boolean @default(false)
  modalityOtherText String  @default("")

  // TcMEP Concerns
  tcmepNone         Boolean @default(false)
  tcmepSeizures     Boolean @default(false)
  tcmepSkullDefects Boolean @default(false)
  tcmepDefibrillator Boolean @default(false)
  tcmepOtherText    String  @default("")
  tcmepImplants     Boolean @default(false)
  tcmepSpinalCord   Boolean @default(false)
  tcmepDBS          Boolean @default(false)
  tcmepCochlearImpl Boolean @default(false)

  // Symptoms
  symptomAtaxia       Boolean @default(false)
  symptomHeadaches    Boolean @default(false)
  symptomPain         Boolean @default(false)
  symptomVision       Boolean @default(false)
  symptomBalance      Boolean @default(false)
  symptomHearing      Boolean @default(false)
  symptomParalysis    Boolean @default(false)
  symptomVomiting     Boolean @default(false)
  symptomBurning      Boolean @default(false)
  symptomIncontinence Boolean @default(false)
  symptomSpasticity   Boolean @default(false)
  symptomWeakness     Boolean @default(false)
  symptomCognitive    Boolean @default(false)
  symptomMemory       Boolean @default(false)
  symptomSpeech       Boolean @default(false)
  symptomNaseau       Boolean @default(false)
  symptomStroke       Boolean @default(false)
  symptomDizziness    Boolean @default(false)
  symptomNumbness     Boolean @default(false)
  symptomTingling     Boolean @default(false)
  symptomOtherText    String  @default("")

  // Legal Acknowledgments
  ackInformedConsent  Boolean @default(false)
  ackAssignmentRights Boolean @default(false)
  ackAuthRelease      Boolean @default(false)
  ackSurpriseBalance  Boolean @default(false)
  ackFinancialResp    Boolean @default(false)

  // Other Medical History
  otherMedicalHistory String @default("")

  // Patient Signature
  patientGuardianName     String @default("")
  patientSignature        String @default("")
  patientSignatureDate    String @default("")

  // Technician fields (filled by staff)
  technicianName      String @default("")
  technicianSignature String @default("")
  technicianDate      String @default("")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?
}

model OnCallEntry {
  id        String   @id @default(cuid())
  techName  String
  date      String
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OnCallCoverageRequest {
  id            String   @id @default(cuid())
  userId        String
  requesterName String   @default("")
  dates         String   @default("[]")
  reason        String   @default("")
  status        String   @default("pending")
  managerNote   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TimeOffRequest {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName   String
  startDate  String
  endDate    String
  reason     String   @default("")
  status     String   @default("pending")
  reviewedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WorkEntry {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facilityName   String   @default("")
  date           String   // YYYY-MM-DD
  startTime      String   // HH:MM (24h)
  endTime        String   // HH:MM (24h)
  travelMinutes  Int      @default(0)
  notes          String   @default("")
  billingFormId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RoleRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName      String
  userEmail     String
  requestedRole String   // "technician" | "manager"
  status        String   @default("pending") // "pending" | "approved" | "denied"
  reviewedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CalendarEvent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdByName String
  title         String
  date          String   // YYYY-MM-DD
  startTime     String   @default("") // HH:MM or empty
  endTime       String   @default("") // HH:MM or empty
  location      String   @default("")
  description   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BillingForm {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId    String?
  case      PatientCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Header
  invoiceNumber   String @default("")
  poNumber        String @default("")
  patientName     String @default("")
  age             String @default("")
  genderMale      Boolean @default(false)
  genderFemale    Boolean @default(false)
  referringDoctor String @default("")
  roomNumber      String @default("")
  patientAcctNumber String @default("")
  patientMRN        String @default("")
  techName        String @default("")
  facility        String @default("")
  date            String @default("")
  procedure       String @default("")

  // Evoked Potentials CPT quantities
  cptVisual           String @default("")
  cptAuditory         String @default("")
  cptUpperExtremities String @default("")
  cptLowerExtremities String @default("")
  cptUpperMotorEP     String @default("")
  cptLowerMotorEP     String @default("")
  cptRLNMonitoring    String @default("")

  // EMG/Nerve Conduction CPT quantities
  cptTwoExtEMG          String @default("")
  cptFourExtEMG         String @default("")
  cptCranialUnilateral  String @default("")
  cptCranialBilateral   String @default("")
  cptElectrocorticography String @default("")
  cptStatFee            String @default("")
  cptStandby            String @default("")
  standbyHours          String @default("")

  // EEG/Monitoring
  cptEEG      String @default("")
  flatFeeMEP  String @default("")
  baseline    String @default("")

  // Timing & Equipment
  startTime      String @default("")
  endTime        String @default("")
  electrodesUsed String @default("")
  thyroidKit     String @default("")
  ssepEMG        String @default("")
  fluobeam       String @default("")
  pedicleProbe   String @default("")
  needleCount    String @default("")
  needlesUsed    String @default("")
  needlesRemoved String @default("")

  // Summary
  totalHours   String @default("")
  drivingTime  String @default("")
  computerUsed String @default("")
  cancellation String @default("")
  neurologist  String @default("")

  // Signatures
  technicianSignature     String @default("")
  technicianSignatureDate String @default("")
  rnSignature             String @default("")
  rnSignatureDate         String @default("")
}

model CaseStudyForm {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId    String?
  case      PatientCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientName          String @default("")
  date                 String @default("")
  technicianName       String @default("")
  craniotomyDiagnosis  String @default("")
  selectedProcedures   String @default("[]")
  procedureOther       String @default("")
  electrodePickupSites String @default("[]")
  electrodeOther       String @default("")
  selectedEPNerves     String @default("[]")
  selectedEMGMuscles   String @default("[]")
  problemsOrSignalLoss String @default("")
  diabetic             Boolean @default(false)
  patientHistory       String @default("")
  technicianSignature  String @default("")
}

model MedicalLienForm {
  id            String   @id @default(cuid())
  userId        String
  caseId        String
  status        String   @default("draft")
  patientName   String   @default("")
  dateOfAccident String  @default("")
  dateOfSurgery  String  @default("")
  iomCharges     String  @default("")
  patientSignature     String @default("")
  patientRepName       String @default("")
  patientDate          String @default("")
  attorneySignature    String @default("")
  attorneyName         String @default("")
  attorneyDate         String @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  case  PatientCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model MissedHoursRequest {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facilityName   String   @default("")
  date           String   // YYYY-MM-DD
  startTime      String   // HH:MM
  endTime        String   // HH:MM
  travelMinutes  Int      @default(0)
  notes          String   @default("")
  reason         String   @default("")
  status         String   @default("pending") // pending, approved, denied
  reviewedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OnCallRotation {
  id        String   @id @default("singleton")
  names     String   @default("[]")   // JSON array: ["Alice", "Bob", "Charlie"]
  startDate String   @default("")     // YYYY-MM-DD of the Monday the first tech's rotation begins
  updatedAt DateTime @updatedAt
}

model PatientCase {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientName String
  date        String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  billingForms    BillingForm[]
  consentForms    ConsentForm[]
  caseStudyForms  CaseStudyForm[]
  medicalLienForms MedicalLienForm[]
}
